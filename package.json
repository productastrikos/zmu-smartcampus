{
  "name": "zmu-smart-campus-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "ZMU Smart Digital Campus — Enterprise Platform POC (Astrikos S!aP demo). Full-stack dashboard: Express API over CSV datasets + React/Vite/Tailwind client.",
  "scripts": {
    "generate": "node server/generate/generate-data.js",
    "server": "node server/index.js",
    "client": "vite",
    "dev": "concurrently -k -n api,web -c blue,green \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "npm run build && node server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "express": "^4.19.2",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.7",
    "sass": "^1.77.8",
    "tailwindcss": "^3.4.6",
    "three": "^0.184.0",
    "vite": "^5.3.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
